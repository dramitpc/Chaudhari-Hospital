# ─────────────────────────────────────────────────────────────────
#  Copy this file to deploy/.env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── Option A: local PostgreSQL container (default) ────────────────
# Strong random password for the PostgreSQL database user.
# Generate one with:  openssl rand -base64 32
DB_PASSWORD=change_me_strong_password

# ── Option B: remote / Replit-hosted database ─────────────────────
# Paste the full DATABASE_URL from Replit Secrets here.
# When this is set, use docker-compose.remote-db.yml instead of
# docker-compose.yml so the local postgres container is skipped.
# DATABASE_URL=postgres://...

# ── Required for both options ─────────────────────────────────────

# Secret used to sign JWT tokens — must be long and random.
# Generate one with:  openssl rand -base64 48
SESSION_SECRET=change_me_long_random_secret

# Port on the NAS host that the app will be accessible on.
# Default is 8888. Use 80 only if DSM is NOT using it.
HOST_PORT=8888
