# ─────────────────────────────────────────────────────────────────
#  Copy this file to deploy/.env and fill in your values.
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Strong random password for the PostgreSQL database user
# Generate one with:  openssl rand -base64 32
DB_PASSWORD=change_me_strong_password

# Secret used to sign JWT tokens — must be long and random
# Generate one with:  openssl rand -base64 48
SESSION_SECRET=change_me_long_random_secret

# Port on the NAS host that the app will be accessible on.
# Default is 80. Use a high port (e.g. 8888) if 80 is already taken.
HOST_PORT=80

# (Optional) OpenAI API key — enables prescription translation on self-hosted NAS.
# Get your key from: https://platform.openai.com/api-keys
# Leave blank to disable translation.
OPENAI_API_KEY=
