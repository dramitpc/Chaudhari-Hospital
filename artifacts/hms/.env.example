# ─────────────────────────────────────────────────────────────────
#  Vercel / standalone frontend deployment
#  Copy to artifacts/hms/.env.local and fill in your values.
#  Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────

# Base URL of your API server (Express backend).
# Required when the frontend is hosted separately from the API
# (e.g. Vercel frontend + Replit/NAS API).
# Example: https://your-clinicos-api.replit.app
# Leave blank when the frontend and API are on the same origin.
VITE_API_BASE_URL=
